<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Cat - Whisker Wellness</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <h1>Edit Cat</h1>
    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>
    <form action="/cats/<%= cat.id %>/edit" method="POST" enctype="multipart/form-data">
      <label for="name">Name:</label>
      <input type="text" id="name" name="name" value="<%= cat.name %>" required>
      
      <label for="breed">Breed:</label>
      <input list="breedList" type="text" id="breed" name="breed" value="<%= cat.breed || '' %>">
      <datalist id="breedList">
        <% if (breeds && breeds.length) { %>
          <% breeds.forEach(breed => { %>
            <option value="<%= breed.name %>"></option>
          <% }) %>
        <% } %>
      </datalist>
      
      <label for="age">Age:</label>
      <input type="number" id="age" name="age" value="<%= cat.age || '' %>">
      
      <label for="starting_weight">Starting Weight (lbs):</label>
      <input type="number" step="0.1" id="starting_weight" name="starting_weight" value="<%= cat.starting_weight %>" required>
      
      <label for="target_weight">Target Weight (lbs):</label>
      <input type="number" step="0.1" id="target_weight" name="target_weight" value="<%= cat.target_weight %>" required>
      
      <label for="image_url">Image URL (optional):</label>
      <input type="url" id="image_url" name="image_url" value="<%= cat.image_url && !cat.image_url.startsWith('/uploads/') ? cat.image_url : '' %>">
      
      <label for="image_file">Or Upload New Image File:</label>
      <input type="file" id="image_file" name="image_file" accept="image/*">
      
      <button type="submit">Update Cat</button>
    </form>
    <a href="/cats">Back to Cats</a>
  </div>
</body>
</html>