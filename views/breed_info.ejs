<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Breed Information - Whisker Wellness</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <h1>Breed Information for <%= cat.name %></h1>
    <p>Breed: <strong><%= cat.breed || 'Unknown' %></strong></p>
    <p>Current weight: <strong><%= cat.starting_weight %> lbs</strong></p>
    <h2>Recommended Weight</h2>
    <p><%= recommendedWeight %></p>
    <% if (averageWeight) { %>
      <p>Breed average weight: <%= averageWeight %> lbs</p>
    <% } %>
    <p><strong><%= comparison %></strong></p>

    <% if (breed) { %>
      <h2>Breed Facts</h2>
      <p>Activity level: <%= breed.activity_level %></p>
      <p>Grooming needs: <%= breed.grooming_needs %></p>
      <p>Health concerns: <%= breed.common_health_concerns %></p>
      <p><%= breed.notes %></p>
    <% } else { %>
      <p>Breed information not available for this profile.</p>
    <% } %>

    <a href="/cats" class="button">Back to Cats</a>
  </div>
</body>
</html>
